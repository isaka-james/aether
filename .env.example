# Copy to .env and edit. The backend (Docker) reads these via the AETHER_ prefix.

# --- Auth (single user) ---
AETHER_USERNAME=admin
AETHER_PASSWORD=changeme
AETHER_JWT_SECRET=change-me-to-a-long-random-string

# --- Shared secret between backend and the host agent (MUST match the agent) ---
AETHER_HOST_AGENT_TOKEN=change-me-to-a-long-random-string

# --- LLM: DeepSeek (cloud, OpenAI-compatible) ---
DEEPSEEK_KEY=sk-your-deepseek-api-key
AETHER_DEEPSEEK_MODEL=deepseek-chat          # or deepseek-reasoner for R1

# --- Host root password (for approved sudo commands; leave empty to disable) ---
ROOT_PWD=

# --- N.E.W.S. integration (optional — enables "what's the news") ---
AETHER_NEWS_URL=http://host.docker.internal:4291/api
AETHER_NEWS_EMAIL=
AETHER_NEWS_PASSWORD=

# --- Host agent on the host ---
AETHER_HOST_AGENT_URL=http://host.docker.internal:8765

# --- Postgres + Redis (started by docker-compose; the backend degrades gracefully if
#     they're unreachable). POSTGRES_PASSWORD is read by the db service AND folded into the
#     default AETHER_DATABASE_URL in docker-compose. Override the two URLs only if you run
#     your own external instances.
POSTGRES_PASSWORD=aether
# AETHER_DATABASE_URL=postgresql://aether:aether@db:5432/aether
# AETHER_REDIS_URL=redis://redis:6379/0
AETHER_CONTEXT_TTL=600             # seconds of follow-up conversation memory kept in Redis
AETHER_NEWS_CACHE_TTL=300          # seconds to cache the news briefing in Redis

# --- Speech-to-text ---
# auto = keyless online (Google) first, local whisper fallback; google = online only;
# local = whisper only. auto/google send the recorded audio to Google's public speech API.
AETHER_STT_PROVIDER=auto
AETHER_WHISPER_MODEL=small.en      # local fallback: tiny | base | small | small.en | medium
AETHER_WHISPER_COMPUTE_TYPE=int8

# --- Text-to-speech (Kokoro, CPU) ---
AETHER_KOKORO_VOICE=af_sky

# --- Behavior ---
AETHER_SPEAK_ON_HOST=true
AETHER_REQUIRE_CONFIRM_MEDIUM_RISK=true
AETHER_ENABLE_REVIEW=true          # second AI pass reviews each result before replying
