# Aether configuration. Copy this to .env and edit:  cp .env.example .env
#
# The backend reads AETHER_-prefixed names; a few well-known keys (DEEPSEEK_API_KEY,
# OPENAI_API_KEY, ANTHROPIC_API_KEY, ROOT_PWD, POSTGRES_PASSWORD) use their usual names.
# Keep comments on their own lines, not after a value. Never commit your real .env.

# ----- 1. Login (protects the whole app) -----
AETHER_USERNAME=admin
AETHER_PASSWORD=change-me-before-exposing
# A long random string. Make one with:  openssl rand -hex 32
AETHER_JWT_SECRET=change-me-to-a-long-random-string

# ----- 2. Shared secret between the backend and the host agent -----
# Must match on both sides. Make one with:  openssl rand -hex 32
AETHER_HOST_AGENT_TOKEN=change-me-to-a-long-random-string

# ----- 3. AI model (pick one provider) -----
# Providers: deepseek, openai, anthropic, local, openai-compatible
AETHER_LLM_PROVIDER=deepseek
# Optional. Leave blank to use the provider's default model / endpoint.
AETHER_LLM_MODEL=
AETHER_LLM_BASE_URL=
# Only the selected provider's key is needed.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AETHER_LLM_API_KEY=

# ----- 4. About you (optional, for greetings) -----
AETHER_USER_NAME=
AETHER_USER_CITY=
AETHER_USER_COUNTRY=
# Your timezone, e.g. Europe/Berlin, America/New_York, Africa/Nairobi. Blank uses UTC.
AETHER_TZ=

# ----- 5. Admin password for approved sudo commands (optional) -----
# Leave empty to turn sudo commands off entirely.
ROOT_PWD=

# ----- 6. Ports and host agent -----
# Uncommon on purpose, so they do not clash with common dev ports (3000, 5000, 8000...).
AETHER_WEB_PORT=8473
AETHER_AGENT_PORT=8474
AETHER_HOST_AGENT_URL=http://host.docker.internal:8474

# ----- 7. Database and cache (optional, started by docker compose) -----
POSTGRES_PASSWORD=aether
# Only set these if you run your own external Postgres / Redis:
# AETHER_DATABASE_URL=postgresql://aether:aether@db:5432/aether
# AETHER_REDIS_URL=redis://redis:6379/0
AETHER_CONTEXT_TTL=600

# ----- 8. Voice typing (speech to text) -----
# auto = online first then local; google = online only; local = on device only.
AETHER_STT_PROVIDER=auto
AETHER_WHISPER_MODEL=small.en
AETHER_WHISPER_COMPUTE_TYPE=int8

# ----- 9. Voice (text to speech) -----
AETHER_KOKORO_VOICE=af_sky

# ----- 10. Behaviour -----
AETHER_SPEAK_ON_HOST=true
AETHER_REQUIRE_CONFIRM_MEDIUM_RISK=true
AETHER_ENABLE_REVIEW=true

# Multi-agent: let the main loop delegate focused sub-goals to specialist sub-agents
# (media / desktop / knowledge / general) and run several in parallel — good for "do X,
# Y and Z" requests. Set false for the classic single agent. The other two bound how hard
# each delegation works (steps per sub-agent, and how many run at once).
AETHER_SUBAGENTS_ENABLED=true
AETHER_SUBAGENT_MAX_STEPS=6
AETHER_MAX_PARALLEL_AGENTS=3
